{
  "name": "docs",
  "version": "1.0.0",
  "description": "All the docs, all the info.",
  "main": "index.js",
  "scripts": {
    "fmt": "prettier --write '**/*.md' --ignore-path .prettierignore",
    "fmt:check": "prettier --check '**/*.md' --ignore-path .prettierignore",
    "lint:specs": "redocly lint api/proposals/openapi.yaml",
    "postman:proposals": "openapi2postmanv2 -s api/proposals/openapi.yaml -o downloads/_files/ekklesia-proposals-api.postman_collection.json -p",
    "postman": "npm run postman:proposals",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --config __tests/jest.config.js",
    "test:voting": "node --experimental-vm-modules node_modules/.bin/jest --config __tests/jest.config.js --testPathPatterns=__tests/voting",
    "test:proposals": "node --experimental-vm-modules node_modules/.bin/jest --config __tests/jest.config.js --testPathPatterns=__tests/proposals",
    "env:up": "docker compose -f docker-compose.test.yml up -d && echo 'Waiting for services...' && sleep 8 && docker compose -f docker-compose.test.yml logs seed --no-log-prefix",
    "env:down": "docker compose -f docker-compose.test.yml down",
    "env:reset": "docker compose -f docker-compose.test.yml down -v && npm run env:up",
    "env:logs": "docker compose -f docker-compose.test.yml logs -f"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lerna-Labs/ekklesia-docs.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/Lerna-Labs/ekklesia-docs/issues"
  },
  "homepage": "https://github.com/Lerna-Labs/ekklesia-docs#readme",
  "devDependencies": {
    "@redocly/cli": "^2.25.4",
    "dotenv": "^17.4.1",
    "jest": "^30.3.0",
    "jsonwebtoken": "^9.0.3",
    "openapi-to-postmanv2": "^6.0.0",
    "prettier": "^3.8.1"
  }
}
